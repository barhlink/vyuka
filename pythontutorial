      <div class="chapter-list">
        ${CHAPTERS.map((c,i)=>`<div class="ch-chip" onclick="jumpToChapter(${i})"><span class="ch-icon">${c.icon}</span><span class="ch-name">${c.title}</span></div>`).join('')}
      </div>
      <button class="go-btn" onclick="startGame()">Začít od začátku →</button>
    </div>`;
