    </div>`;
  renderMain(html);
}

function showTheory(){
  phase='theory';
  const c = CHAPTERS[ci];
  const t = c.theory;
  const codeLines = t.lines.map(l=>`<div class="cl">${l.t||'&nbsp;'}</div>`).join('');
  const annotHtml = t.annots.map(a=>`<div class="annot"><span class="annot-key">${a.k}</span><span class="annot-val">${a.v}</span></div>`).join('');
  const html = `
    <div class="theory-card">
      <div class="theory-eyebrow">Jak to funguje?</div>
      <div class="theory-heading">${t.heading}</div>
      <div class="theory-text">${t.text}</div>
      <div class="code-ex">${codeLines}</div>
      <div class="annots">${annotHtml}</div>
      <button class="next-theory-btn" onclick="startExercises()">Procvičit →</button>
    </div>`;
  renderMain(html);
}

function startExercises(){
  ei = 0; chCorrect = 0;
  showExercise();
}

