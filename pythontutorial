// ─── STATE ──────────────────────────────────────────────────────────────────
let phase = 'title'; // title|intro|theory|exercise|ch-done|win
let ci = 0;       // chapter index
let ei = 0;       // exercise index
let attempts = 0; // attempts on current exercise
let xp = 0;
let chXP = []; // xp per chapter
let timerSec = 0; let timerInt = null;
let chCorrect = 0; // correct in current chapter
let totalCorrect = 0;

// ─── HELPERS ────────────────────────────────────────────────────────────────
function totalExercises(){return CHAPTERS.reduce((s,c)=>s+c.exercises.length,0)}
function doneExercises(){
  let n=0;
  for(let i=0;i<ci;i++) n+=CHAPTERS[i].exercises.length;
  if(phase==='exercise'||phase==='ch-done'||phase==='win') n+=ei;
  return n;
}

function updateHeader(){
  const tot = totalExercises();
  const done = doneExercises();
  const pct = Math.round(done/tot*100);
  document.getElementById('progFill').style.width = pct+'%';
  document.getElementById('progLabel').textContent =
    phase==='title'? '—' : CHAPTERS[ci]? CHAPTERS[ci].title : 'Hotovo!';
  document.getElementById('progPct').textContent = pct+'%';
  document.getElementById('xpVal').textContent = xp;

  // pips
  const pip = document.getElementById('pips');
  pip.innerHTML = CHAPTERS.map((_,i)=>{
    let cls='pip';
    if(i<ci) cls+=' done';
    else if(i===ci) cls+=' active';
    return `<div class="${cls}"></div>`;
  }).join('');
}

function startTimer(){
  timerInt = setInterval(()=>{
    timerSec++;
    const m=String(Math.floor(timerSec/60)).padStart(2,'0');
    const s=String(timerSec%60).padStart(2,'0');
    document.getElementById('timerEl').textContent=`${m}:${s}`;
  },1000);
}

function hl(s){return s;} // syntax already in HTML

function renderMain(html){
  const el = document.getElementById('main');
  el.style.animation='none';
  void el.offsetWidth;
  el.style.animation='';
  el.innerHTML = html;
  updateHeader();
}

// ─── PHASES ─────────────────────────────────────────────────────────────────

