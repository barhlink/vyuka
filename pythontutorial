  // Build code lines — replace [[BLANK]] with input
  const codeHtml = ex.lines.map(line=>{
    if(line.includes('[[BLANK]]')){
      const parts = line.split('[[BLANK]]');
      return `<span class="cl">${parts[0]}<input class="blank" id="blankInput" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" placeholder="?" />${parts[1]||''}</span>`;
    }
    return `<span class="cl">${line||'&nbsp;'}</span>`;
  }).join('');

  const html = `
    <div class="ex-rule"></div>
    <div class="ex-label">
      <span>${ex.label}</span>
      <span>${ei+1} / ${totalEx}</span>
    </div>
    <div class="ex-instruction">${ex.instruction}</div>
    <div class="fill-block" id="fillBlock">${codeHtml}</div>
    <div class="submit-row">
      <button class="check-btn" id="checkBtn" onclick="checkAnswer()">Zkontrolovat</button>
      <button class="hint-btn" id="hintBtn" onclick="showHint()">Nápověda</button>
      <span class="attempts-txt" id="attTxt"></span>
    </div>
    <div class="fb" id="fb"></div>
    <button class="next-ex-btn" id="nextBtn" onclick="advanceExercise()">
      ${ei < totalEx-1 ? 'Další cvičení →' : 'Dokončit kapitolu →'}
    </button>`;

  renderMain(html);

  const inp = document.getElementById('blankInput');
  if(inp){
    inp.focus();
    inp.addEventListener('keydown', e=>{ if(e.key==='Enter') checkAnswer(); });
    inp.addEventListener('input', ()=>{
      inp.style.width = Math.max(48, inp.value.length * 9.5 + 20) + 'px';
    });
    inp.style.width = '72px';
  }
}

function checkAnswer(){
  const inp = document.getElementById('blankInput');
  if(!inp) return;
  const val = inp.value.trim();
  if(!val) return;

  const ex = CHAPTERS[ci].exercises[ei];
  const correct = ex.blank.trim();

  const isOk = val === correct;
  attempts++;

  const fb = document.getElementById('fb');
  const block = document.getElementById('fillBlock');
  const nextBtn = document.getElementById('nextBtn');
  const checkBtn = document.getElementById('checkBtn');
  const attTxt = document.getElementById('attTxt');

  if(isOk){
    inp.classList.add('ok');
    inp.disabled = true;
    block.classList.add('correct');
    checkBtn.disabled = true;
    document.getElementById('hintBtn').disabled = true;
    xp += attempts === 1 ? 10 : 5;
    chCorrect++;
    totalCorrect++;
    fb.className='fb show ok';
    fb.innerHTML=`<span class="fb-icon">✦</span><div class="fb-body"><strong>${ex.ok.split('.')[0]}.</strong>${ex.ok.split('.').slice(1).join('.')}</div>`;
    nextBtn.classList.add('show');
    updateHeader();
  } else {
    inp.classList.add('err');
    block.classList.add('wrong');
    setTimeout(()=>{
      block.classList.remove('wrong');
      inp.classList.remove('err');
    }, 400);

    if(attempts >= 2){
      // Reveal
      inp.value = correct;
      inp.style.width = Math.max(48, correct.length * 9.5 + 20) + 'px';
      inp.classList.add('ok');
      inp.disabled = true;
      block.classList.add('correct');
      checkBtn.disabled = true;
      document.getElementById('hintBtn').disabled = true;
      fb.className='fb show reveal';
      fb.innerHTML=`<span class="fb-icon">→</span><div class="fb-body"><strong>Správná odpověď: ${escHtml(correct)}</strong>${ex.no}</div>`;
      nextBtn.classList.add('show');
    } else {
      fb.className='fb show look';
      fb.innerHTML=`<span class="fb-icon">→</span><div class="fb-body"><strong>Zkus znovu.</strong>${ex.no}</div>`;
      attTxt.textContent = `Pokus ${attempts} / 2`;
      setTimeout(()=>{ const i = document.getElementById('blankInput'); if(i){ i.value=''; i.style.width='72px'; i.focus(); }},100);
    }
  }
}

function showHint(){
  const ex = CHAPTERS[ci].exercises[ei];
  const fb = document.getElementById('fb');
  fb.className='fb show hint';
  fb.innerHTML=`<span class="fb-icon">💡</span><div class="fb-body"><strong>Nápověda</strong>${ex.hint}</div>`;
}

function advanceExercise(){
  ei++;
  const c = CHAPTERS[ci];
  if(ei >= c.exercises.length){
    showChapterDone();
  } else {
    showExercise();
  }
}

function showChapterDone(){
  phase='ch-done';
  const c = CHAPTERS[ci];
  const tot = c.exercises.length;
  const earned = Math.min(chCorrect, tot);
  chXP.push(earned);

  const msgs = [
    ['Kapitola zvládnuta.', `Prošel/a jsi všemi ${tot} cvičeními kapitoly ${c.title}.`],
    ['Docela slušný výkon.', `${earned} z ${tot} správně napoprvé — to je dobrý základ.`],
    ['Kapitola za tebou.', `Každé cvičení ukázalo, jak ${c.title} funguje v praxi.`],
  ];
  const [h, b] = msgs[earned === tot ? 0 : earned >= Math.ceil(tot/2) ? 1 : 2];

  const isLast = ci >= CHAPTERS.length - 1;
  const html = `
    <div class="ch-done">
      <div class="done-icon">${c.icon}</div>
      <div class="done-title">${h}</div>
      <div class="done-sub">${b}</div>
      <div class="done-stats">
        <div class="done-stat"><div class="done-stat-val">${earned}/${tot}</div><div class="done-stat-lbl">Správně</div></div>
        <div class="done-stat"><div class="done-stat-val">${xp}</div><div class="done-stat-lbl">Celkem XP</div></div>
      </div>
      <button class="continue-btn" onclick="${isLast ? 'showWin()' : 'nextChapter()'}">
        ${isLast ? 'Zobrazit výsledky →' : 'Další kapitola →'}
      </button>
    </div>`;
  renderMain(html);
}

function nextChapter(){
  ci++;
  chCorrect = 0;
  showChapterIntro();
}

function showWin(){
  phase='win';
  clearInterval(timerInt);
  const m=String(Math.floor(timerSec/60)).padStart(2,'0');
  const s=String(timerSec%60).padStart(2,'0');
  const tot = totalExercises();
  const pct = Math.round(totalCorrect/tot*100);
  const msgs = [
    ['Výborná práce.', `Prošel/a jsi všemi kapitolami a procvičil/a si základy Python syntaxe. Teď víš, jak print, proměnné, podmínky, smyčky i funkce vypadají v praxi.`],
    ['Dobrý pokrok.', `${totalCorrect} z ${tot} cvičení správně — základ Python syntaxe máš. Pár věcí se ještě sedá na místo, ale to je přesně k čemu procvičování slouží.`],
    ['Začátek je za tebou.', `${totalCorrect} z ${tot} správně. Každá chyba ukázala, co ještě posílit. Kurz lze spustit znovu a projít ještě jednou.`],
  ];
  const [h,b] = msgs[pct>=90?0:pct>=60?1:2];

  const html = `
    <div class="win">
      <div class="win-label">Kurz dokončen</div>
      <div class="win-title">${h}</div>
      <div class="win-sub">${b}</div>
      <div class="win-grid">
        <div class="win-stat"><div class="win-stat-val">${totalCorrect}/${tot}</div><div class="win-stat-lbl">Správných odpovědí</div></div>
        <div class="win-stat"><div class="win-stat-val">${pct} %</div><div class="win-stat-lbl">Úspěšnost</div></div>
        <div class="win-stat"><div class="win-stat-val">${xp}</div><div class="win-stat-lbl">Získané XP</div></div>
        <div class="win-stat"><div class="win-stat-val">${m}:${s}</div><div class="win-stat-lbl">Celkový čas</div></div>
      </div>
      <button class="restart-link" onclick="restartGame()">↺ Spustit znovu od začátku</button>
    </div>`;
  renderMain(html);
  updateHeader();
}

function escHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}

// ─── FLOW ────────────────────────────────────────────────────────────────────
function startGame(){
  ci=0; ei=0; xp=0; timerSec=0; chCorrect=0; totalCorrect=0; chXP=[];
  clearInterval(timerInt);
  startTimer();
  showChapterIntro();
}


function jumpToChapter(idx){
  ci=idx; ei=0; chCorrect=0;
  if(!timerInt) startTimer();
  showChapterIntro();
}
function restartGame(){
  ci=0; ei=0; xp=0; timerSec=0; chCorrect=0; totalCorrect=0; chXP=[];
  clearInterval(timerInt);
  document.getElementById('timerEl').textContent='00:00';
  showTitle();
}

// ─── INIT ────────────────────────────────────────────────────────────────────
document.getElementById('pips').innerHTML = CHAPTERS.map(()=>`<div class="pip"></div>`).join('');
showTitle();
</script>
</body>
</html>
