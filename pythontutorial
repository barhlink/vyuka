<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Python Tutorial</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#fafafa;--fg:#111;--mid:#555;--muted:#999;--light:#e5e5e5;--lighter:#f4f4f4;
  --green:#15803d;--green-bg:#f0fdf4;--green-b:#bbf7d0;
  --red:#dc2626;--red-bg:#fef2f2;--red-b:#fecaca;
  --blue:#1d4ed8;--blue-bg:#eff6ff;--blue-b:#bfdbfe;
  --amber:#b45309;--amber-bg:#fffbeb;--amber-b:#fde68a;
  --code-bg:#f7f7f7;
  --kw:#7c3aed;--str:#16a34a;--num:#ea580c;--fn:#1d4ed8;--cm:#9ca3af;
}
html{font-size:16px}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--fg);min-height:100vh}

.shell{max-width:660px;margin:0 auto;padding:0 24px 80px}

/* top bar */
.topbar{
  padding:26px 0 18px;margin-bottom:36px;
  border-bottom:1px solid var(--light);
  display:flex;align-items:center;justify-content:space-between;
}
.brand{font-family:'DM Serif Display',serif;font-size:1.05rem;letter-spacing:-0.3px}
.brand small{font-family:'DM Sans',sans-serif;font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);display:block;margin-top:2px}
.top-right{display:flex;align-items:center;gap:16px}
.xp-badge{font-family:'DM Mono',monospace;font-size:0.78rem;color:var(--muted);letter-spacing:0.5px}
.xp-badge span{color:var(--fg);font-weight:500}
.timer{font-family:'DM Mono',monospace;font-size:0.82rem;color:var(--muted)}

/* progress */
.prog-wrap{margin-bottom:40px}
.prog-meta{display:flex;justify-content:space-between;margin-bottom:8px;font-size:0.72rem;color:var(--muted);font-weight:500;letter-spacing:0.5px}
.prog-track{height:2px;background:var(--light)}
.prog-fill{height:100%;background:var(--fg);transition:width .5s cubic-bezier(.4,0,.2,1)}
.chapter-pips{display:flex;gap:4px;margin-top:8px}
.pip{flex:1;height:3px;background:var(--light);border-radius:2px;transition:background .4s}
.pip.done{background:var(--fg)}
.pip.active{background:var(--mid)}

/* main content */
#main{animation:fadeUp .3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* title screen */
.title-screen{padding:20px 0 10px}
.title-eyebrow{font-size:0.68rem;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:20px}
.title-h{font-family:'DM Serif Display',serif;font-size:2.8rem;letter-spacing:-1.5px;line-height:1.05;margin-bottom:14px}
.title-h em{font-style:italic;color:var(--mid)}
.title-sub{font-size:0.95rem;color:var(--mid);line-height:1.65;max-width:420px;margin-bottom:36px}
.chapter-list{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:40px}
.ch-chip{padding:10px 14px;border:1px solid var(--light);border-radius:5px;font-size:0.78rem;color:var(--mid);display:flex;align-items:center;gap:8px;cursor:pointer;transition:border-color .15s,background .15s}
.ch-chip:hover{border-color:#aaa;background:var(--lighter)}
.ch-chip .ch-icon{font-size:1rem}
.ch-chip .ch-name{font-weight:500;color:var(--fg)}
.go-btn{padding:13px 40px;background:var(--fg);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.9rem;font-weight:500;cursor:pointer;transition:opacity .2s;letter-spacing:0.3px}
.go-btn:hover{opacity:.8}

/* chapter intro */
.ch-intro{padding:16px 0}
.ch-num{font-size:0.68rem;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:16px}
.ch-title-row{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.ch-icon-big{font-size:2rem}
.ch-title{font-family:'DM Serif Display',serif;font-size:2.2rem;letter-spacing:-1px}
.ch-tagline{font-size:0.95rem;color:var(--mid);margin-bottom:28px;line-height:1.6;max-width:400px}
.start-btn{padding:12px 36px;background:var(--fg);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.88rem;font-weight:500;cursor:pointer;transition:opacity .2s;letter-spacing:0.3px}
.start-btn:hover{opacity:.8}

/* theory card */
.theory-card{margin-bottom:0}
.theory-eyebrow{font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:16px}
.theory-heading{font-family:'DM Serif Display',serif;font-size:1.6rem;letter-spacing:-0.5px;margin-bottom:10px;line-height:1.2}
.theory-text{font-size:0.93rem;color:var(--mid);line-height:1.7;margin-bottom:24px}

/* code example block */
.code-ex{background:var(--code-bg);border:1px solid var(--light);border-radius:6px;padding:18px 20px;margin-bottom:16px;font-family:'DM Mono',monospace;font-size:0.83rem;line-height:2;position:relative;overflow-x:auto}
.code-ex .cl{display:block;white-space:pre}

/* annotations */
.annots{display:flex;flex-direction:column;gap:7px;margin-bottom:28px}
.annot{display:flex;gap:10px;align-items:baseline;font-size:0.82rem}
.annot-key{font-family:'DM Mono',monospace;font-size:0.78rem;background:var(--lighter);padding:2px 8px;border-radius:3px;white-space:nowrap;flex-shrink:0;color:var(--fg)}
.annot-val{color:var(--mid);line-height:1.5}

.next-theory-btn{padding:12px 36px;background:var(--fg);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.88rem;font-weight:500;cursor:pointer;transition:opacity .2s;letter-spacing:0.3px}
.next-theory-btn:hover{opacity:.8}

/* exercise */
.ex-rule{height:1px;background:var(--light);margin:32px 0}
.ex-label{font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:6px;display:flex;justify-content:space-between}
.ex-instruction{font-family:'DM Serif Display',serif;font-size:1.4rem;letter-spacing:-0.3px;margin-bottom:22px;line-height:1.3}

/* code fill block */
.fill-block{background:var(--code-bg);border:1px solid var(--light);border-radius:6px;padding:18px 20px;margin-bottom:22px;font-family:'DM Mono',monospace;font-size:0.83rem;line-height:2.2;position:relative;overflow-x:auto}
.fill-block .cl{display:block;white-space:pre-wrap}
.fill-block.correct{border-color:var(--green);background:var(--green-bg)}
.fill-block.wrong{border-color:var(--red);background:var(--red-bg);animation:shake .3s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}

/* the input blank */
.blank{
  display:inline-block;
  font-family:'DM Mono',monospace;font-size:0.83rem;
  border:none;border-bottom:2px solid var(--blue);
  background:#e8f0fe;color:var(--fg);
  padding:1px 6px;border-radius:3px 3px 0 0;
  outline:none;min-width:48px;
  transition:background .15s,border-color .15s;
  vertical-align:baseline;
}
.blank:focus{background:#d1e4ff;border-color:#1a56db}
.blank.ok{background:var(--green-bg);border-color:var(--green);color:var(--green)}
.blank.err{background:var(--red-bg);border-color:var(--red);color:var(--red)}

/* submit row */
.submit-row{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.check-btn{padding:10px 28px;background:var(--fg);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.87rem;font-weight:500;cursor:pointer;transition:opacity .2s;letter-spacing:0.3px}
.check-btn:hover{opacity:.8}
.check-btn:disabled{opacity:.35;cursor:default}
.hint-btn{background:none;border:1px solid var(--light);border-radius:5px;padding:9px 18px;font-family:'DM Sans',sans-serif;font-size:0.82rem;color:var(--muted);cursor:pointer;transition:border-color .15s,color .15s}
.hint-btn:hover{border-color:#aaa;color:var(--fg)}
.attempts-txt{font-size:0.75rem;color:var(--muted);font-family:'DM Mono',monospace}

/* feedback */
.fb{display:none;border-radius:5px;padding:13px 16px;font-size:0.87rem;line-height:1.6;margin-bottom:20px;animation:fbIn .3s ease}
@keyframes fbIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.fb.show{display:flex;gap:11px;align-items:flex-start}
.fb.ok{background:var(--green-bg);border:1px solid var(--green-b);color:#166534}
.fb.hint{background:var(--amber-bg);border:1px solid var(--amber-b);color:#92400e}
.fb.look{background:var(--blue-bg);border:1px solid var(--blue-b);color:#1e40af}
.fb.reveal{background:var(--lighter);border:1px solid var(--light);color:var(--mid)}
.fb-icon{flex-shrink:0;margin-top:1px;font-size:0.85rem}
.fb-body strong{display:block;margin-bottom:2px;font-weight:600;font-size:0.9rem}

.next-ex-btn{display:none;width:100%;padding:13px;background:var(--fg);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.88rem;font-weight:500;cursor:pointer;transition:opacity .2s,transform .15s;letter-spacing:0.3px}
.next-ex-btn.show{display:block}
.next-ex-btn:hover{opacity:.85;transform:translateY(-1px)}

/* chapter done */
.ch-done{text-align:center;padding:32px 0}
.done-icon{font-size:3rem;margin-bottom:20px;animation:pop .5s cubic-bezier(.34,1.56,.64,1)}
@keyframes pop{from{transform:scale(0)}to{transform:scale(1)}}
.done-title{font-family:'DM Serif Display',serif;font-size:2rem;letter-spacing:-0.8px;margin-bottom:10px}
.done-sub{font-size:0.92rem;color:var(--mid);max-width:340px;margin:0 auto 30px;line-height:1.65}
.done-stats{display:flex;justify-content:center;gap:24px;margin-bottom:36px}
.done-stat{text-align:center}
.done-stat-val{font-family:'DM Serif Display',serif;font-size:1.8rem;letter-spacing:-0.5px}
.done-stat-lbl{font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-top:2px}
.continue-btn{padding:13px 44px;background:var(--fg);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.9rem;font-weight:500;cursor:pointer;transition:opacity .2s;letter-spacing:0.3px}
.continue-btn:hover{opacity:.8}

/* win screen */
.win{padding:24px 0}
.win-label{font-size:0.68rem;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:20px}
.win-title{font-family:'DM Serif Display',serif;font-size:3rem;letter-spacing:-2px;line-height:1;margin-bottom:16px}
.win-sub{font-size:0.95rem;color:var(--mid);line-height:1.65;max-width:380px;margin-bottom:40px}
.win-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:40px}
.win-stat{padding:16px 18px;border:1px solid var(--light);border-radius:5px}
.win-stat-val{font-family:'DM Serif Display',serif;font-size:1.9rem;letter-spacing:-0.8px;margin-bottom:3px}
.win-stat-lbl{font-size:0.67rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);font-weight:600}
.restart-link{background:none;border:none;font-family:'DM Sans',sans-serif;font-size:0.88rem;color:var(--muted);cursor:pointer;text-decoration:underline;text-underline-offset:3px;padding:0}
.restart-link:hover{color:var(--fg)}

/* syntax colors */
.kw{color:var(--kw)}.str{color:var(--str)}.num{color:var(--num)}.fn{color:var(--fn)}.cm{color:var(--cm);font-style:italic}

@media(max-width:480px){
  .chapter-list{grid-template-columns:1fr}
  .title-h{font-size:2.2rem}
  .win-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div class="shell">
  <div class="topbar">
    <div class="brand">Python Tutorial<small>Syntaxe krok za krokem</small></div>
    <div class="top-right">
      <div class="xp-badge">XP <span id="xpVal">0</span></div>
      <div class="timer" id="timerEl">00:00</div>
    </div>
  </div>
  <div class="prog-wrap">
    <div class="prog-meta">
      <span id="progLabel">—</span>
      <span id="progPct">0 %</span>
    </div>
    <div class="prog-track"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
    <div class="chapter-pips" id="pips"></div>
  </div>
  <div id="main"></div>
</div>

<script>
// ─── DATA ───────────────────────────────────────────────────────────────────
const CHAPTERS = [
  {
    icon:'💬', color:'#1d4ed8',
    title:'print()',
    tagline:'Základní příkaz pro výpis — bez něj bychom nic neviděli.',
    theory:{
      heading:'Jak Python ukáže text?',
      text:'Příkaz <b>print()</b> zobrazí cokoli, co vložíme do závorek. Text musí být v uvozovkách " " — tak Python pozná, že jde o slova, ne příkazy.',
      lines:[
        {t:`<span class='fn'>print</span>(<span class='str'>"Ahoj světe!"</span>)`},
        {t:`<span class='fn'>print</span>(<span class='str'>"Jak se máš?"</span>)`},
        {t:`<span class='fn'>print</span>(<span class='num'>42</span>)  <span class='cm'># číslo bez uvozovek</span>`},
      ],
      annots:[
        {k:'print',v:'příkaz pro výpis — přesně toto slovo, nic jiného'},
        {k:'()',v:'závorky jsou povinné — Python nezná print bez nich'},
        {k:'"..."',v:'uvozovky ohraničují text — bez nich Python hledá proměnnou'},
      ]
    },
    exercises:[
      {
        instruction:'Doplň příkaz, který zobrazí text:',
        label:'Cvičení 1',
        lines:[`[[BLANK]]("Dobrý den!")`],
        blank:'print',
        hint:'Začíná na p — pět písmen',
        ok:'print() je klíčové slovo. Závorky jsou součástí příkazu — bez nich Python neví, co vypsat.',
        no:'Klíčové slovo je print. Pak hned závorky. Zkus to napsat znovu.'
      },
      {
        instruction:'Doplň text tak, aby se zobrazilo slovo <strong>Hurá!</strong>',
        label:'Cvičení 2',
        lines:[`print([[BLANK]])`],
        blank:'"Hurá!"',
        hint:'Text patří do uvozovek: "Hurá!"',
        ok:'Text v uvozovkách — Python ví, že jde o slova. Bez uvozovek by hledal proměnnou s tímto jménem.',
        no:'Text musí být ohraničen uvozovkami: "Hurá!". Uvozovky jsou součástí odpovědi.'
      }
    ]
  },
  {
    icon:'📦', color:'#be185d',
    title:'Proměnné',
    tagline:'Pojmenované krabičky, do kterých ukládáme hodnoty.',
    theory:{
      heading:'Co je proměnná?',
      text:'Proměnná je jako krabička s názvem. Pomocí znaku <b>=</b> do ní uložíme hodnotu. Vlevo je vždy název, vpravo hodnota. Jméno si vybíráme sami.',
      lines:[
        {t:`jméno <span class='kw'>=</span> <span class='str'>"Eva"</span>`},
        {t:`věk  <span class='kw'>=</span> <span class='num'>12</span>`},
        {t:`<span class='fn'>print</span>(jméno)  <span class='cm'># Vypíše: Eva</span>`},
        {t:`<span class='fn'>print</span>(věk)   <span class='cm'># Vypíše: 12</span>`},
      ],
      annots:[
        {k:'=',v:'uložení hodnoty — jedno rovnítko, ne dvě'},
        {k:'jméno',v:'název proměnné — libovolné slovo bez mezer'},
        {k:'"Eva"',v:'text v uvozovkách; číslo píšeme bez uvozovek'},
      ]
    },
    exercises:[
      {
        instruction:'Doplň operátor pro uložení hodnoty:',
        label:'Cvičení 1',
        lines:[`věk [[BLANK]] 10`],
        blank:'=',
        hint:'Jedno rovnítko — ne dvě!',
        ok:'= ukládá hodnotu. == (dvě) porovnává — to jsou různé věci.',
        no:'Uložení hodnoty = jedno rovnítko. Dvě == by byly porovnání. Zkus znovu.'
      },
      {
        instruction:'Doplň název proměnné pro jméno:',
        label:'Cvičení 2',
        lines:[`[[BLANK]] = "Tomáš"`,`print(jméno)`],
        blank:'jméno',
        hint:'Na druhém řádku vidíš, jaká proměnná se vypisuje',
        ok:'Proměnnou pojmenujeme a pak ji používáme všude stejně — velká a malá písmena záleží.',
        no:'Podívej se na druhý řádek — co je uvnitř print()? Přesně takhle se musí jmenovat proměnná.'
      },
      {
        instruction:'Ulož do proměnné barva hodnotu <strong>modrá</strong>:',
        label:'Cvičení 3',
        lines:[`barva = [[BLANK]]`,`print(barva)`],
        blank:'"modrá"',
        hint:'Text patří do uvozovek — napiš "modrá" včetně uvozovek',
        ok:'Textová hodnota v uvozovkách — Python pak ví, že jde o slova, ne název proměnné.',
        no:'Hodnota musí být v uvozovkách: "modrá". Uvozovky jsou součástí odpovědi.'
      }
    ]
  },
  {
    icon:'🔢', color:'#ea580c',
    title:'Čísla a výpočty',
    tagline:'Python umí sčítat, odčítat, násobit i dělit.',
    theory:{
      heading:'Python jako kalkulačka',
      text:'Čísla píšeme <b>bez uvozovek</b>. Python zvládá základní matematiku přímo uvnitř print() nebo při uložení do proměnné. Výsledek spočítá sám.',
      lines:[
        {t:`<span class='fn'>print</span>(<span class='num'>3</span> <span class='kw'>+</span> <span class='num'>5</span>)   <span class='cm'># Vypíše: 8</span>`},
        {t:`<span class='fn'>print</span>(<span class='num'>10</span> <span class='kw'>-</span> <span class='num'>4</span>)  <span class='cm'># Vypíše: 6</span>`},
        {t:`<span class='fn'>print</span>(<span class='num'>3</span> <span class='kw'>*</span> <span class='num'>4</span>)   <span class='cm'># Vypíše: 12</span>`},
        {t:`<span class='fn'>print</span>(<span class='num'>10</span> <span class='kw'>/</span> <span class='num'>2</span>)  <span class='cm'># Vypíše: 5.0</span>`},
      ],
      annots:[
        {k:'3 + 5',v:'čísla bez uvozovek — Python je sečte'},
        {k:'"3" + "5"',v:'text v uvozovkách — Python by vypsal "35", ne 8!'},
        {k:'**',v:'umocnění: 2**3 = 8 (dva na třetí)'},
      ]
    },
    exercises:[
      {
        instruction:'Doplň operátor pro součet:',
        label:'Cvičení 1',
        lines:[`print(7 [[BLANK]] 3)  # Výsledek: 10`],
        blank:'+',
        hint:'Klasické znaménko pro sčítání',
        ok:'+ sečte dvě čísla. Python vypíše výsledek, ne "7 + 3".',
        no:'Sčítání se píše znaménkem +. Zkus znovu.'
      },
      {
        instruction:'Doplň operátor pro násobení:',
        label:'Cvičení 2',
        lines:[`print(5 [[BLANK]] 4)  # Výsledek: 20`],
        blank:'*',
        hint:'V Pythonu se násobení nepíše ×, ale jiným znakem',
        ok:'* je operátor násobení. × nebo · Python nezná — vždy musíme psát hvězdičku.',
        no:'Násobení v Pythonu je hvězdička *. Zkus to.'
      },
      {
        instruction:'Doplň výpočet průměru:',
        label:'Cvičení 3',
        lines:[`součet = 10 + 20 + 30`,`průměr = součet [[BLANK]] 3`,`print(průměr)`],
        blank:'/',
        hint:'Dělení — jeden ze čtyř základních operátorů',
        ok:'/ je dělení. Výsledek bude 20.0 — Python vrátí desetinné číslo.',
        no:'Dělení se píše lomítkem /. Zkus znovu.'
      }
    ]
  },
  {
    icon:'📝', color:'#6b7280',
    title:'Komentáře',
    tagline:'Poznámky v kódu, které Python přeskočí.',
    theory:{
      heading:'Co je komentář?',
      text:'Komentář začíná znakem <b>#</b>. Python přeskočí vše, co je za # na daném řádku — nevykoná to, nevypíše to. Komentáře slouží pro nás — jako poznámky.',
      lines:[
        {t:`<span class='cm'># Toto je komentář — Python ho přeskočí</span>`},
        {t:`<span class='fn'>print</span>(<span class='str'>"Ahoj"</span>)  <span class='cm'># Inline komentář</span>`},
        {t:`<span class='cm'># Tuto část kódu dočasně vypínám:</span>`},
        {t:`<span class='cm'># print("Tohle se nevypíše")</span>`},
      ],
      annots:[
        {k:'#',v:'znak mřížky — začíná komentář, Python vše za ním přeskočí'},
        {k:'za kódem',v:'komentář může být na samostatném řádku nebo za příkazem'},
        {k:'# kód',v:'komentování kódu — způsob, jak ho dočasně vypnout'},
      ]
    },
